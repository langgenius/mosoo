---
import CardVisual from "./CardVisual.astro";

interface Props {
  href: string;
  title: string;
  category: string;
  date: Date;
  description?: string | undefined;
  slug: string;
  heroImage?: string | undefined;
  heroAlt?: string | undefined;
}
const { href, title, category, date, description, slug, heroImage, heroAlt } = Astro.props;
const dateLabel = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-[var(--r-lg)] border border-[color:var(--border)] bg-[color:var(--surface)] shadow-[var(--shadow-xs)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[var(--shadow-md)]"
>
  <CardVisual slug={slug} heroImage={heroImage} heroAlt={heroAlt} ratio="16/9" />
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-center gap-2.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[color:var(--fg-muted)]">
      <span>{dateLabel}</span>
      <span class="text-[color:var(--ink-200)]">·</span>
      <span class="inline-flex items-center gap-1.5 text-[color:var(--accent-text)]">
        <span class="block h-1.5 w-1.5 rounded-full bg-[color:var(--green-500)]" />
        {category}
      </span>
    </div>
    <h3 class="font-display text-[20px] font-medium leading-[1.2] tracking-[-0.015em] text-[color:var(--ink-950)] transition-colors group-hover:text-[color:var(--accent-press)]">
      {title}
    </h3>
    {
      description && (
        <p class="text-[14px] leading-[1.55] text-[color:var(--fg-secondary)] line-clamp-2">
          {description}
        </p>
      )
    }
    <div class="mt-auto pt-2 font-mono text-[11.5px] font-semibold uppercase tracking-[0.08em] text-[color:var(--fg-muted)]">
      Read post →
    </div>
  </div>
</a>
