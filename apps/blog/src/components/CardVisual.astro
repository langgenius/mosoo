---
import { gradientFromSlug } from "../lib/gradient-from-slug";

interface Props {
  slug: string;
  ratio?: "16/9" | "4/3" | "3/2" | "21/9";
  label?: string;
}
const { slug, ratio = "16/9", label } = Astro.props;
const visual = gradientFromSlug(slug);
const aspect =
  ratio === "16/9"
    ? "aspect-[16/9]"
    : ratio === "4/3"
      ? "aspect-[4/3]"
      : ratio === "21/9"
        ? "aspect-[21/9]"
        : "aspect-[3/2]";
---

<div
  class:list={[
    "relative w-full overflow-hidden",
    aspect,
  ]}
  style={`background: ${visual.background}`}
>
  <!-- Soft horizon band — adds the painterly "edge between sky and land". -->
  <div
    class="absolute inset-x-0 top-[58%] h-px"
    style={`background: ${visual.palette[2]}; box-shadow: 0 0 var(--horizon-blur) ${visual.palette[2]};`}
  >
  </div>
  {
    label && (
      <span class="absolute left-4 top-4 rounded-full bg-[color:var(--paper-100)]/85 px-2.5 py-1 font-mono text-[11px] uppercase tracking-[0.06em] text-[color:var(--fg-1)] backdrop-blur-sm">
        {label}
      </span>
    )
  }
</div>
