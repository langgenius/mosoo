---
import { gradientFromSlug } from "../lib/gradient-from-slug";

interface Props {
  slug: string;
  ratio?: "16/9" | "4/3" | "3/2" | "21/9";
  heroImage?: string | undefined;
  heroAlt?: string | undefined;
  label?: string;
}
const {
  slug,
  ratio = "16/9",
  heroImage,
  heroAlt,
  label,
} = Astro.props;
const visual = gradientFromSlug(slug);
const aspect =
  ratio === "16/9"
    ? "aspect-[16/9]"
    : ratio === "4/3"
      ? "aspect-[4/3]"
      : ratio === "21/9"
        ? "aspect-[21/9]"
        : "aspect-[3/2]";
---

<div class:list={["relative w-full overflow-hidden bg-[color:var(--ink-50)]", aspect]}>
  {
    heroImage ? (
      <img
        src={heroImage}
        alt={heroAlt ?? ""}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover object-center"
      />
    ) : (
      <>
        <div
          class="absolute inset-0"
          style={`background: ${visual.background}`}
        />
        <div
          class="absolute inset-x-0 top-[58%] h-px"
          style={`background: ${visual.palette[2]}; box-shadow: 0 0 var(--horizon-blur) ${visual.palette[2]};`}
        />
      </>
    )
  }
  {
    label && (
      <span class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-[var(--r-sm)] bg-white/90 px-2 py-1 font-mono text-[10.5px] font-semibold uppercase tracking-[0.08em] text-[color:var(--ink-900)] backdrop-blur-sm">
        <span class="block h-1.5 w-1.5 rounded-full bg-[color:var(--green-500)]" />
        {label}
      </span>
    )
  }
</div>
