---
interface Props {
  categories: readonly string[];
  active?: string;
}
const { categories, active = "All" } = Astro.props;
const all = ["All", ...categories];
---

<div
  class="flex flex-wrap items-center gap-2 overflow-x-auto"
  data-category-tabs
>
  {
    all.map((c) => (
      <button
        type="button"
        data-category={c}
        class:list={[
          "rounded-[var(--r-md)] border px-3.5 py-1.5 text-[13px] font-medium tracking-[-0.01em] transition-colors",
          c === active
            ? "border-[color:var(--ink-900)] bg-[color:var(--ink-900)] text-white"
            : "border-[color:var(--border)] bg-[color:var(--surface)] text-[color:var(--fg-secondary)] hover:border-[color:var(--border-strong)] hover:text-[color:var(--fg)]",
        ]}
      >
        {c}
      </button>
    ))
  }
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    "[data-category-tabs] [data-category]",
  );
  const cards = document.querySelectorAll<HTMLElement>("[data-card]");
  const select = (category: string): void => {
    buttons.forEach((b) => {
      const isActive = b.dataset.category === category;
      b.classList.toggle("border-[color:var(--ink-900)]", isActive);
      b.classList.toggle("bg-[color:var(--ink-900)]", isActive);
      b.classList.toggle("text-white", isActive);
      b.classList.toggle("border-[color:var(--border)]", !isActive);
      b.classList.toggle("bg-[color:var(--surface)]", !isActive);
      b.classList.toggle("text-[color:var(--fg-secondary)]", !isActive);
    });
    cards.forEach((c) => {
      c.style.display =
        category === "All" || c.dataset["category"] === category ? "" : "none";
    });
  };
  buttons.forEach((b) =>
    b.addEventListener("click", () => select(b.dataset.category ?? "All")),
  );
</script>
