---
const year = 2026;
const base = import.meta.env.BASE_URL;
---

<footer class="border-border-default mt-20 border-t">
  <div class="mx-auto flex w-full max-w-[1280px] flex-col gap-4 px-4 py-10 md:flex-row md:items-center md:justify-between md:px-6">
    <div class="font-mono text-[12px] uppercase tracking-[0.06em] text-[color:var(--fg-3)]">
      © {year} Mosoo · Notes from the bamboo grove
    </div>
    <div class="flex items-center gap-5 text-[13px] text-[color:var(--fg-2)]">
      <a href="/" class="hover:text-[color:var(--fg-1)]">mosoo.ai</a>
      <a href={`${base}/rss.xml`} class="hover:text-[color:var(--fg-1)]">RSS</a>
      <a
        href="https://github.com/langgenius/mosoo"
        class="hover:text-[color:var(--fg-1)]">GitHub</a
      >
    </div>
  </div>
</footer>
