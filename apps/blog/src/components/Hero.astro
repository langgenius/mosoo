---
import CardVisual from "./CardVisual.astro";
import { getPostHref } from "../lib/i18n";
import type { CollectionEntry } from "astro:content";

interface Props {
  featured: CollectionEntry<"blog">;
  base: string;
}
const { featured, base } = Astro.props;
const href = getPostHref(featured, base);
const dateLabel = featured.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={href}
  class="group block"
>
  <div class="grid grid-cols-1 md:grid-cols-[0.95fr_1.05fr]">
    <div class="md:order-2">
      <CardVisual
        slug={featured.id}
        heroImage={featured.data.heroImage}
        heroAlt={featured.data.heroAlt ?? featured.data.title}
        ratio="16/9"
        label={featured.data.category}
      />
    </div>
    <div class="flex flex-col gap-4 pt-5 md:order-1 md:pt-0 md:pr-10 lg:pr-12">
      <div class="font-mono text-[11.5px] font-semibold uppercase tracking-[0.08em] text-[color:var(--fg-muted)]">
        Featured · {dateLabel}
      </div>
      <h2 class="font-display text-[30px] font-medium leading-[1.05] tracking-[-0.02em] text-[color:var(--ink-950)] transition-colors group-hover:text-[color:var(--accent-press)] md:text-[38px]">
        {featured.data.title}
      </h2>
      <p class="text-[15px] leading-[1.5] text-[color:var(--fg-secondary)]">
        {featured.data.description}
      </p>
      <div class="mt-auto flex items-center gap-3 text-[13px] text-[color:var(--fg-secondary)]">
        <span class="font-medium">{featured.data.author}</span>
        <span class="text-[color:var(--ink-300)]">·</span>
        <span class="inline-flex items-center gap-1.5">
          <span class="block h-1.5 w-1.5 rounded-full bg-[color:var(--green-500)]" />
          <span class="text-[color:var(--accent-text)] font-semibold">
            {featured.data.category}
          </span>
        </span>
      </div>
      <div class="font-mono text-[11.5px] font-semibold uppercase tracking-[0.08em] text-[color:var(--accent-text)]">
        Read post →
      </div>
    </div>
  </div>
</a>
