---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  author?: string;
}
const {
  title,
  description,
  canonical,
  ogImage,
  type = "website",
  publishedTime,
  author,
} = Astro.props;
const cleanPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalUrl = canonical ?? new URL(cleanPath, Astro.site).href;
const ogImageUrl = ogImage ?? new URL("/og-default.png", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/blog/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="mosoo blog"
      href="/blog/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="mosoo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      type === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )
    }
    {type === "article" && author && <meta property="article:author" content={author} />}
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[color:var(--paper)] text-[color:var(--ink-900)]">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
