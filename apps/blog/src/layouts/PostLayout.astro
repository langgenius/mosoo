---
import BaseLayout from "./BaseLayout.astro";
import CardVisual from "../components/CardVisual.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { title, description, date, category, author, heroImage, heroAlt } =
  post.data;
const dateLabel = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  ...(heroImage
    ? { image: new URL(heroImage, Astro.site).href }
    : {}),
  author: { "@type": "Person", name: author },
  publisher: {
    "@type": "Organization",
    name: "mosoo",
    url: "https://mosoo.ai",
  },
  url: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout
  title={`${title} · mosoo blog`}
  description={description}
  type="article"
  publishedTime={date}
  author={author}
  ogImage={heroImage ? new URL(heroImage, Astro.site).href : undefined}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    slot="head"
  />

  <article class="mx-auto w-full max-w-[760px] px-6 py-14 md:py-20">
    <a
      href="/blog"
      class="mb-10 inline-flex items-center gap-2 font-mono text-[11.5px] font-semibold uppercase tracking-[0.08em] text-[color:var(--fg-muted)] transition-colors hover:text-[color:var(--fg)]"
    >
      ← Back to all posts
    </a>

    <div class="mb-4 flex items-center gap-3 font-mono text-[11.5px] font-semibold uppercase tracking-[0.08em] text-[color:var(--fg-muted)]">
      <span>{dateLabel}</span>
      <span class="text-[color:var(--ink-300)]">·</span>
      <span class="inline-flex items-center gap-1.5 text-[color:var(--accent-text)]">
        <span class="block h-1.5 w-1.5 rounded-full bg-[color:var(--green-500)]" />
        {category}
      </span>
    </div>

    <h1 class="mb-5 font-display text-[42px] font-medium leading-[1.05] tracking-[-0.025em] text-[color:var(--ink-950)] md:text-[56px]">
      {title}
    </h1>

    <p class="mb-8 text-[19px] leading-[1.55] text-[color:var(--fg-secondary)]">
      {description}
    </p>

    <div class="mb-12 flex items-center gap-3 text-[14px] text-[color:var(--fg-secondary)]">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[color:var(--green-100)] font-semibold text-[color:var(--accent-text)]">
        {author.slice(0, 1).toUpperCase()}
      </span>
      <span>By {author}</span>
    </div>

    <div class="mb-14 overflow-hidden rounded-[var(--r-xl)] border border-[color:var(--border)] shadow-[var(--shadow-sm)]">
      <CardVisual
        slug={post.id}
        heroImage={heroImage}
        heroAlt={heroAlt ?? title}
        ratio="3/2"
      />
    </div>

    <div class="prose-mosoo">
      <slot />
    </div>

    <hr class="my-16 border-[color:var(--border)]" />

    <div class="flex items-center justify-between text-[13px] text-[color:var(--fg-secondary)]">
      <a
        href="/blog"
        class="font-mono font-semibold uppercase tracking-[0.08em] hover:text-[color:var(--fg)]"
        >← More posts</a
      >
      <a
        href="https://mosoo.ai/login"
        class="inline-flex items-center gap-2 rounded-[var(--r-md)] bg-[color:var(--green-500)] px-3.5 py-2 font-semibold text-[color:var(--fg-on-accent)] transition-colors hover:bg-[color:var(--green-600)]"
        >Try mosoo →</a
      >
    </div>
  </article>
</BaseLayout>
