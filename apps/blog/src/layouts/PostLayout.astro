---
import BaseLayout from "./BaseLayout.astro";
import CardVisual from "../components/CardVisual.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { title, description, date, category, author } = post.data;
const dateLabel = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: { "@type": "Person", name: author },
  publisher: {
    "@type": "Organization",
    name: "Mosoo",
    url: "https://mosoo.ai",
  },
  url: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout
  title={`${title} · Mosoo Blog`}
  description={description}
  type="article"
  publishedTime={date}
  author={author}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    slot="head"
  />

  <article class="mx-auto w-full max-w-[760px] px-4 py-12 md:px-6 md:py-16">
    <a
      href="/blog"
      class="font-mono mb-8 inline-flex items-center gap-2 text-[12px] uppercase tracking-[0.06em] text-[color:var(--fg-3)] hover:text-[color:var(--fg-1)]"
      >← Back to all posts</a
    >

    <div class="font-mono mb-3 flex items-center gap-3 text-[12px] uppercase tracking-[0.06em] text-[color:var(--fg-3)]">
      <span>{dateLabel}</span>
      <span>·</span>
      <span class="text-[color:var(--accent-press)]">{category}</span>
    </div>

    <h1
      class="font-display mb-4 text-[40px] font-bold leading-[1.05] tracking-[-0.01em] text-[color:var(--fg-1)] md:text-[52px]"
    >
      {title}
    </h1>

    <p class="mb-8 text-[18px] leading-[1.5] text-[color:var(--fg-2)]">
      {description}
    </p>

    <div class="mb-10 text-[13px] text-[color:var(--fg-3)]">By {author}</div>

    <div class="border-border-default mb-12 overflow-hidden border">
      <CardVisual slug={post.id} ratio="21/9" />
    </div>

    <div class="prose-mosoo">
      <slot />
    </div>

    <hr class="my-16 border-[color:var(--border-default)]" />

    <div class="flex items-center justify-between text-[13px] text-[color:var(--fg-2)]">
      <a
        href="/blog"
        class="font-mono uppercase tracking-[0.06em] hover:text-[color:var(--fg-1)]"
        >← More posts</a
      >
      <a href="https://mosoo.ai/login" class="t-link">Try Mosoo →</a>
    </div>
  </article>
</BaseLayout>
